# AIRKit (https://developers.sandbox.air3.com)
NEXT_PUBLIC_PARTNER_ID=
NEXT_PUBLIC_ISSUER_DID=
NEXT_PUBLIC_CREDENTIAL_ID=        # Issuer → Programs (Issuance Program ID)
NEXT_PUBLIC_PROGRAM_ID=           # Verifier → Programs (Verification Program ID)

# JWT signing. Server only.
# Generate: openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt
AIRKIT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
AIRKIT_KEY_ID=your-key-id

# MongoDB (frame configs storage)
MONGODB_URI=
MONGODB_DB_NAME=

# Public origin used by /embed metadata (Twitter card og:image, twitter:player, etc.)
# In dev, point this at your tunnel URL (cloudflared/ngrok). In prod, set to your real domain.
NEXT_PUBLIC_SITE_URL=

# /test page: the "See it live on X" card links here. Should be a public tweet URL.
# e.g. https://x.com/LeoFranklin015/status/1234567890
NEXT_PUBLIC_DEMO_TWEET_URL=
